# Environment
NODE_ENV=development

# Shopify
## Storefront API
NEXT_PUBLIC_SHOPIFY_REVALIDATION_SECRET=""
NEXT_PUBLIC_SHOPIFY_PRIVATE_STOREFRONT_API_TOKEN="<your-private-token>"
NEXT_PUBLIC_SHOPIFY_PUBLIC_STOREFRONT_API_TOKEN="<your-public-token>"
NEXT_PUBLIC_SHOPIFY_STOREFRONT_URL="https://mock.shop/"
NEXT_PUBLIC_SHOPIFY_STOREFRONT_API_VERSION="2025-07"

## Customer Account API
# For public (web) clients Shopify does not issue a client secret; leave blank if using
# the 'Öffentlich (Web-App)' client type as shown in the screenshot.
SHOPIFY_CUSTOMER_API_CLIENT_ID="<your-client-id>"
SHOPIFY_CUSTOMER_API_CLIENT_SECRET="" # optional for public clients
# The OAuth URLs below must be copied verbatim from the Customer Account API
# client configuration in the Shopify admin.  They include a numeric segment
# (e.g. `74609164552`) that is not the same as the client ID and cannot be
# derived automatically, so we require the full URL strings.
SHOPIFY_CUSTOMER_API_AUTH_URL="https://shopify.com/authentication/XXXXXXXXXXXX/oauth/authorize"
SHOPIFY_CUSTOMER_API_TOKEN_URL="https://shopify.com/authentication/XXXXXXXXXXXX/oauth/token"
#SHOPIFY_CUSTOMER_API_LOGOUT_URL="https://shopify.com/authentication/XXXXXXXXXXXX/logout"  # optional

# space-separated (or comma-separated) list of scopes granted to your
# Customer Account API client. The application normalizes commas to spaces and
# removes duplicates. The value must correspond to permissions enabled in the
# Shopify admin for the client; you can use either the granular headless
# scopes or the composite GraphQL scope.
#
# Examples:
#   customer_read_customers customer_read_orders             # granular
#   customer_read_customers,customer_read_orders            # commas allowed
#   customer-account-api:full                               # composite form
SHOPIFY_CUSTOMER_API_SCOPES="customer_read_customers customer_read_orders"
NEXT_PUBLIC_SHOPIFY_CUSTOMER_REDIRECT_URI="https://your-ngrok-url/api/auth/customer/callback"
# Optional shared cookie domain for auth/session cookies.
# Set this in production when both apex and www are used, e.g. ".printtextilien24.de".
SHOPIFY_CUSTOMER_COOKIE_DOMAIN=""
# Rollout flag for strict customer auth/session validation.
# true: strict token validation + refresh fallback (recommended)
# false: legacy cookie-presence session mode for emergency rollback
SHOPIFY_CUSTOMER_AUTH_V2="true"

## Locale
NEXT_PUBLIC_SHOPIFY_COUNTRY_ISO_CODE="EN"
NEXT_PUBLIC_SHOPIFY_LANGUAGE_ISO_CODE="EN"


# Public API URL
NEXT_PUBLIC_API_URL="https://example.com/api"

# Supabase
SUPABASE_URL="https://your-supabase-url.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
# Email via SMTP (nodemailer)
# example using IONOS account:
# SMTP_HOST="smtp.ionos.de"
# SMTP_PORT="465"           # SSL/TLS
# SMTP_USER="your@ionos-domain"
# SMTP_PASS="your-password"
# SMTP_FROM="no-reply@yourdomain"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="username"
SMTP_PASS="password"
SMTP_FROM="no-reply@example.com"
# address that will receive contact form submissions
CONTACT_EMAIL="sales@example.com"

# Feature flags
# disable personalization/customizer by default
NEXT_PUBLIC_ENABLE_CUSTOMIZATION="false"


# ERecht24 API
# optional; if you don't have a key leave it blank. the literal
# placeholder above won't actually work and will produce a 404 error
# (harmless, logged to the console).
ERECHT24_API_KEY="your-api-key"
